---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/BlogCard.astro';
import ExternalLinkList from '@components/ExternalLinkList.astro';
import { loadLinks } from '@utils/loadLinks';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const { links } = loadLinks();
---

<BaseLayout
  title="masamichhhi"
  description="Welcome to my personal page - featuring my blog, resume, and links to my work across the web."
>
  <!-- Hero Section -->
  <section class="home-hero py-24 md:py-32 relative overflow-hidden">
    <div class="container text-center relative z-10">
      <div class="mb-8 fade-in-up" style="animation-delay: 0.1s">
        <div class="relative inline-block">
          <img
            src="/profile-8bit.png"
            alt="Masamichi Iimori"
            class="w-32 h-32 md:w-40 md:h-40 rounded-full mx-auto object-cover border-4 shadow-xl float-animation"
            style="border-color: var(--blog-brand)"
          />
          <div class="absolute -inset-2 rounded-full opacity-30" style="background: radial-gradient(circle, var(--blog-brand), transparent 70%); filter: blur(12px);"></div>
        </div>
      </div>
      <h1 class="text-5xl md:text-6xl font-bold mb-6 fade-in-up" style="animation-delay: 0.3s">
        <span class="sr-only">Hello, I'm masamichhhi</span>
        <span
          id="hero-typewriter"
          class="inline-flex items-center font-mono text-4xl md:text-5xl gradient-text"
          aria-hidden="true"
        ></span>
      </h1>
      <p class="text-xl max-w-2xl mx-auto mb-10 fade-in-up blog-muted" style="animation-delay: 0.5s">
        It's pronounced "masamichi" (まさみち). <br/>
        I'm a software engineer passionate about building great products.
        Here you'll find my blog, resume, and links to my work across the web.
      </p>
      <div class="flex flex-wrap justify-center gap-4 fade-in-up" style="animation-delay: 0.7s">
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-xl no-underline font-semibold text-white shadow-lg transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, var(--blog-brand), var(--section-links-accent))"
        >
          Read Blog
          <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a
          href="/aboutme"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl no-underline font-semibold transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 border-2"
          style="border-color: var(--blog-border); color: var(--blog-ink); background: var(--header-blur-bg); backdrop-filter: blur(8px)"
        >
          About me
        </a>
      </div>
    </div>
    <!-- Decorative floating elements -->
    <div class="absolute top-20 left-10 w-20 h-20 rounded-full opacity-20 float-animation" style="background: var(--blog-brand); filter: blur(40px); animation-delay: 0s;"></div>
    <div class="absolute bottom-20 right-10 w-32 h-32 rounded-full opacity-15 float-animation" style="background: var(--section-links-accent); filter: blur(50px); animation-delay: 1.5s;"></div>
    <div class="absolute top-1/2 left-1/4 w-16 h-16 rounded-full opacity-10 float-animation" style="background: var(--section-posts-accent); filter: blur(30px); animation-delay: 0.8s;"></div>
  </section>

  <script is:inline>
    const target = document.getElementById('hero-typewriter');
    if (target) {
      const text = "Hello, I'm masamichhhi";
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        target.textContent = text;
      } else {
        let index = 0;
        const cursor = document.createElement('span');
        cursor.textContent = '▍';
        cursor.style.marginLeft = '0.2em';
        cursor.style.animation = 'blink 1s step-end infinite';
        target.appendChild(cursor);

        const tick = () => {
          if (index <= text.length) {
            target.firstChild?.remove();
            target.textContent = text.slice(0, index);
            target.appendChild(cursor);
            index += 1;
            setTimeout(tick, 70);
          }
        };
        tick();
      }
    }
  </script>

  <!-- External Links Section -->
  {links.length > 0 && (
    <section class="py-16 section-links animate-on-scroll">
      <div class="container">
        <ExternalLinkList links={links} />
      </div>
    </section>
  )}

  <!-- Quick Links Section -->
  <section class="py-20 section-quicklinks animate-on-scroll">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
        <a
          href="/blog"
          class="group block p-8 rounded-2xl border no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-xl relative overflow-hidden"
          style="border-color: var(--blog-border); background: var(--blog-surface-strong)"
        >
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(135deg, rgba(15, 118, 110, 0.05), rgba(124, 58, 237, 0.05))"></div>
          <div class="relative z-10">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg" style="background: linear-gradient(135deg, var(--blog-brand), var(--section-links-accent))">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <h2 class="text-xl font-semibold blog-ink mb-2 transition-colors duration-300" style="font-family: var(--blog-font-display)">
              Blog
            </h2>
            <p class="blog-muted">
              Read my thoughts on technology, development, and more.
            </p>
            <div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-all duration-300 group-hover:gap-2" style="color: var(--blog-brand)">
              Explore
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        </a>

        <a
          href="/aboutme"
          class="group block p-8 rounded-2xl border no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-xl relative overflow-hidden"
          style="border-color: var(--blog-border); background: var(--blog-surface-strong)"
        >
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(135deg, rgba(234, 88, 12, 0.05), rgba(15, 118, 110, 0.05))"></div>
          <div class="relative z-10">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg" style="background: linear-gradient(135deg, var(--section-posts-accent), var(--blog-brand))">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h2 class="text-xl font-semibold blog-ink mb-2 transition-colors duration-300" style="font-family: var(--blog-font-display)">
              About me
            </h2>
            <p class="blog-muted">
              Learn more about my experience, skills, and projects.
            </p>
            <div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-all duration-300 group-hover:gap-2" style="color: var(--blog-brand)">
              Learn more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Blog Posts Section -->
  {recentPosts.length > 0 && (
    <section class="py-20 section-posts animate-on-scroll">
      <div class="container">
        <div class="flex items-center justify-between mb-10">
          <div>
            <p class="blog-label mb-2">Latest</p>
            <h2 class="text-3xl md:text-4xl font-bold blog-ink" style="font-family: var(--blog-font-display)">Recent Posts</h2>
          </div>
          <a
            href="/blog"
            class="group inline-flex items-center gap-1.5 font-semibold no-underline transition-all duration-300"
            style="color: var(--blog-brand)"
          >
            View all
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="space-y-6">
          {recentPosts.map((post, i) => (
            <div class="animate-on-scroll" style={`transition-delay: ${i * 0.1}s`}>
              <BlogCard
                title={post.data.title}
                slug={post.slug}
                publishedAt={post.data.publishedAt}
                summary={post.data.summary}
                tags={post.data.tags}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Scroll reveal animation -->
  <script is:inline>
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    } else {
      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        el.classList.add('is-visible');
      });
    }
  </script>
</BaseLayout>
