---
import { formatDate } from '@utils/formatDate';
import TagList from './TagList.astro';

interface Props {
  title: string;
  slug: string;
  publishedAt: Date;
  summary?: string;
  tags?: string[];
  readingTime?: string;
}

const { title, slug, publishedAt, summary, tags = [], readingTime } = Astro.props;
const safeTitle = title?.trim();
const safeSlug = slug?.trim();
const isValid = Boolean(safeTitle && safeSlug && publishedAt);
---

{isValid && (
  <article class="group blog-card p-6 relative overflow-hidden">
    <div class="absolute left-0 top-0 bottom-0 w-1 rounded-full transition-all duration-300 group-hover:w-1.5" style="background: linear-gradient(to bottom, var(--blog-brand), var(--section-links-accent))"></div>
    <a href={`/blog/${safeSlug}`} class="block no-underline pl-4">
      <div class="flex flex-col gap-3">
        <div class="flex flex-wrap items-center gap-3 text-xs blog-muted">
          <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
          {readingTime && (
            <span class="inline-flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              {readingTime}
            </span>
          )}
        </div>
        <h3 class="text-xl md:text-2xl font-semibold blog-ink transition-colors duration-300" style="font-family: var(--blog-font-display)">
          <span class="group-hover:gradient-text transition-all duration-300">{safeTitle}</span>
        </h3>
        {summary && <p class="blog-muted line-clamp-2">{summary}</p>}
      </div>
    </a>
    {tags.length > 0 && (
      <div class="mt-3 pl-4">
        <TagList tags={tags} linked={false} />
      </div>
    )}
  </article>
)}
