---
import { Icon } from 'astro-icon/components';
import { loadLinks } from '@utils/loadLinks';

const currentYear = new Date().getFullYear();
const { links } = loadLinks();
---

<footer class="mt-auto no-print relative">
  <div class="h-px w-full" style="background: linear-gradient(90deg, transparent, var(--blog-brand), var(--section-links-accent), transparent)"></div>
  <div class="container py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm blog-muted">
        &copy; {currentYear} <span class="font-semibold gradient-text">masamichhhi</span>. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        {links.slice(0, 4).map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="blog-muted transition-all duration-300 hover:-translate-y-0.5"
            style="--hover-color: var(--blog-brand)"
            title={link.platform}
          >
            <Icon name={link.icon} class="w-5 h-5" />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
